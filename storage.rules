rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Only logged-in users can write to their own profile folders
    // Profile images are publicly readable so that we can render user avatars dynamically
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
